root = true

# ── Universal ──────────────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = crlf
indent_style             = space
indent_size              = 4
trim_trailing_whitespace = true
insert_final_newline     = true

[*.{json,yml,yaml,xml,props,targets,csproj,sln}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# ── C# (todos os arquivos) ─────────────────────────────────────────────────
[*.cs]

# Analyzers Roslyn
dotnet_diagnostic.CA1848.severity  = none        # LoggerMessage delegates — custo mínimo
dotnet_diagnostic.VSSpell001.severity = none      # Spell check — termos PT-BR
dotnet_diagnostic.CS8618.severity  = none        # Campos não anuláveis (domain models usam inicialização tardia)

# CA1716: 'Error', 'Shared', 'Result' conflitam com keywords VB.NET mas são
#         nomes de domínio intencionais no Result Pattern deste projeto.
dotnet_diagnostic.CA1716.severity  = none

# S101: Acrônimos em nomes de classe (DTO, etc.) — suprimido globalmente.
#       Nomes legados são migrados de forma incremental.
dotnet_diagnostic.S101.severity    = none

# CA1062: Validar parâmetros públicos — sugestão, não erro.
dotnet_diagnostic.CA1062.severity  = suggestion

# CA2007: ConfigureAwait — não se aplica a ASP.NET Core
dotnet_diagnostic.CA2007.severity  = none

# IDE0290: Construtor primário (C# 12) — sugestão até migração completa
dotnet_diagnostic.IDE0290.severity = suggestion

# ── Migrações EF Core (código gerado) ─────────────────────────────────────
[**/Migrations/*.cs]
generated_code                    = true
dotnet_diagnostic.CS8981.severity = none    # nomes de classe lowercase gerados pelo tooling
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.S3903.severity  = none

# ── Projetos de teste ──────────────────────────────────────────────────────
# xUnit usa a convenção Método_Estado_Resultado (underscores) — CA1707 não se aplica.
[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1716.severity = none    # namespaces de teste podem replicar nomes de domínio
